{
	"compilerOptions": {
		"target": "ES2020",
		"useDefineForClassFields": true,
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"skipLibCheck": true,
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"isolatedModules": true,
		"moduleDetection": "force",
		"noEmit": true,
		"jsx": "react-jsx",
		"strict": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedSideEffectImports": true,
		"baseUrl": ".",
		"paths": {
			"@axiom/mfe-lib-shared": ["../../src/index.ts"],
			"@axiom/mfe-lib-shared/components": ["../../src/components/index.ts"],
			"@axiom/mfe-lib-shared/components/ui": ["../../src/components/shadcn/ui/index.ts"],
			"@axiom/mfe-lib-shared/utils": ["../../src/utils/index.ts"],
			"@axiom/mfe-lib-shared/hooks": ["../../src/hooks/index.ts"],
			"@axiom/mfe-lib-shared/types": ["../../src/types/index.ts"],
			"@axiom/mfe-lib-shared/context": ["../../src/context/index.ts"],
			"@axiom/mfe-lib-shared/api": ["../../src/api/index.ts"],
			"@axiom/mfe-lib-shared/query": ["../../src/query/index.ts"],
			"@axiom/mfe-lib-shared/i18n": ["../../src/i18n/index.ts"],
			"@axiom/mfe-lib-shared/config/eslint": ["../../src/config/eslint/index.ts"],
			"@axiom/mfe-lib-shared/config/prettier": ["../../src/config/prettier/index.ts"]
		}
	},
	"include": [".storybook/**/*", "stories/**/*"]
}
